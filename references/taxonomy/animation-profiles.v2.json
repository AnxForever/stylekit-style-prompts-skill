    "minimal-static": {
      "motion_profile": "minimal",
      "intent": "Eliminates decorative motion to focus exclusively on essential, instantaneous state changes.",
      "trigger": "state-change-only",
      "states": [
        "default",
        "hover",
        "active",
        "focus-visible",
        "disabled"
      ],
      "duration_range_ms": [
        0,
        100
      ],
      "easing": "linear",
      "reduced_motion_fallback": "none",
      "suitable_site_types": [
        "docs",
        "dashboard"
      ],
      "anti_patterns": [
        "Scroll-triggered animations",
        "Auto-playing carousels"
      ]
    },
